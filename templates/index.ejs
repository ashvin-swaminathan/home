<section class="hero">
    <div class="hero-inner">
        <div class="hero-text">
            <h1><%= profile.name %></h1>
            <p class="hero-role"><strong><%= profile.title %></strong><br>
            <a href="<%= profile.institutionUrl %>"><%= profile.institution %></a><br>
            Mentor: <a href="<%= profile.mentorUrl %>"><%= profile.mentor %></a></p>

            <div class="hero-actions">
                <% if (profile.onJobMarket) { %>
                    <span class="job-market">I'm on the job market!</span>
                <% } %>
                <a href="<%= profile.cv %>" class="btn" target="_blank" rel="noopener">Download CV</a>
                <a href="mailto:<%= profile.email %>" class="btn btn-email"><%= profile.email %></a>
                <% if (profile.socialLinks && profile.socialLinks.x) { %>
                    <a href="<%= profile.socialLinks.x %>" class="social-link" target="_blank" rel="noopener" title="X / Twitter"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
                <% } %>
                <% if (profile.socialLinks && profile.socialLinks.linkedin) { %>
                    <a href="<%= profile.socialLinks.linkedin %>" class="social-link" target="_blank" rel="noopener" title="LinkedIn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
                <% } %>
            </div>

            <div class="hero-sections">
                <div class="hero-section">
                    <h3>Research</h3>
                    <p><%- profile.researchBlurb %></p>
                    <p><%- profile.aiBlurb %></p>
                </div>

                <div class="hero-section">
                    <h3>Background</h3>
                    <p><%- profile.education %></p>
                    <% if (profile.currentActivity) { %>
                        <p><%- profile.currentActivity %></p>
                    <% } %>
                </div>

                <div class="hero-section">
                    <p><%- profile.personal %></p>
                </div>
            </div>
        </div>
        <div class="hero-image">
            <img src="<%= profile.photo %>" alt="<%= profile.name %>">
        </div>
    </div>
</section>

<% if (activityFeed && activityFeed.length > 0) { %>
<section class="recent-activity">
    <h2>News</h2>
    <ul class="activity-feed">
        <% activityFeed.forEach(function(item) { %>
            <li class="activity-item">
                <span class="activity-type <%= item.type %>"><%= item.type %></span>
                <div class="activity-text">
                    <% if (item.link) { %><a href="<%= item.link %>" target="_blank" rel="noopener"><%= item.text %></a>
                    <% } else { %><%= item.text %><% } %>
                    <% if (item.detail) { %> <span class="activity-detail">&mdash; <%= item.detail %></span><% } %>
                </div>
            </li>
        <% }); %>
    </ul>
</section>
<% } %>
