<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | <%= profile.name %></title>
    <meta name="description" content="<%= profile.name %> — <%= profile.title %> at <%= profile.institution %>">
    <meta property="og:title" content="<%= title %> | <%= profile.name %>">
    <meta property="og:description" content="<%= profile.title %>, <%= profile.institution %>">
    <meta property="og:type" content="website">
    <meta property="og:image" content="img/og-image.png">
    <link rel="icon" href="img/favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
</head>
